{% comment %}
  Consulting page — Our Legacy /work-shop editorial style
  Magazine/collage layout with scattered images and text blocks
{% endcomment %}

<section class="py-16 md:py-24">
  <!-- Page Header -->
  <div class="px-6 md:px-10 mb-16 md:mb-24">
    <p class="text-xs uppercase tracking-widest text-neutral-500 font-bold mb-2">
      {{ section.settings.label | default: 'Consulting' }}
    </p>
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold uppercase tracking-tighter leading-none">
      {{ page.title | default: 'Consulting' }}
    </h1>
  </div>

  <!-- Editorial Content Grid -->
  <div class="px-6 md:px-10">
    {% for block in section.blocks %}
      {% case block.type %}

        {% when 'large_image' %}
          <div
            class="mb-12 md:mb-20 {% if block.settings.offset %}md:ml-[8%] md:w-[84%]{% else %}w-full{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="aspect-[16/10] bg-neutral-100 overflow-hidden">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1400 | image_tag:
                  class: 'w-full h-full object-cover',
                  loading: 'lazy'
                }}
              {% else %}
                <div class="w-full h-full flex items-center justify-center text-neutral-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              {% endif %}
            </div>
            {% if block.settings.caption != blank %}
              <p class="mt-3 text-xs text-neutral-400">{{ block.settings.caption }}</p>
            {% endif %}
          </div>

        {% when 'image_pair' %}
          <div
            class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-12 md:mb-20 {% if block.settings.offset %}md:px-[4%]{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="aspect-[3/4] bg-neutral-100 overflow-hidden">
              {% if block.settings.image_left != blank %}
                {{ block.settings.image_left | image_url: width: 700 | image_tag:
                  class: 'w-full h-full object-cover',
                  loading: 'lazy'
                }}
              {% else %}
                <div class="w-full h-full flex items-center justify-center text-neutral-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              {% endif %}
            </div>
            <div class="aspect-[3/4] bg-neutral-100 overflow-hidden">
              {% if block.settings.image_right != blank %}
                {{ block.settings.image_right | image_url: width: 700 | image_tag:
                  class: 'w-full h-full object-cover',
                  loading: 'lazy'
                }}
              {% else %}
                <div class="w-full h-full flex items-center justify-center text-neutral-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              {% endif %}
            </div>
          </div>

        {% when 'text_block' %}
          <div
            class="mb-12 md:mb-20 md:max-w-xl {% if block.settings.align == 'right' %}md:ml-auto md:mr-10{% elsif block.settings.align == 'center' %}md:mx-auto{% else %}md:ml-10{% endif %}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.heading != blank %}
              <h2 class="text-2xl md:text-3xl font-bold uppercase tracking-tighter mb-4">
                {{ block.settings.heading }}
              </h2>
            {% endif %}
            {% if block.settings.body != blank %}
              <div class="text-sm md:text-base leading-relaxed text-neutral-600 space-y-4">
                {{ block.settings.body }}
              </div>
            {% endif %}
          </div>

        {% when 'cta' %}
          <div
            class="mb-12 md:mb-20 {% if block.settings.align == 'center' %}text-center{% elsif block.settings.align == 'right' %}text-right{% endif %}"
            {{ block.shopify_attributes }}
          >
            <a
              href="{{ block.settings.url | default: 'https://calendly.com/aminalisaleh/15min' }}"
              target="_blank"
              rel="noopener"
              class="inline-block border border-black px-8 py-3 text-xs uppercase tracking-widest font-bold hover:bg-black hover:text-white transition-colors duration-300"
            >
              {{ block.settings.text | default: 'Book a Consultation' }}
            </a>
          </div>

        {% when 'spacer' %}
          <div class="h-8 md:h-16" {{ block.shopify_attributes }}></div>

      {% endcase %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Consulting",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Top label",
      "default": "Consulting"
    }
  ],
  "blocks": [
    {
      "type": "large_image",
      "name": "Large Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "checkbox",
          "id": "offset",
          "label": "Offset from edges",
          "default": false
        }
      ]
    },
    {
      "type": "image_pair",
      "name": "Image Pair",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_left",
          "label": "Left image"
        },
        {
          "type": "image_picker",
          "id": "image_right",
          "label": "Right image"
        },
        {
          "type": "checkbox",
          "id": "offset",
          "label": "Offset from edges",
          "default": true
        }
      ]
    },
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body text"
        },
        {
          "type": "select",
          "id": "align",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "cta",
      "name": "CTA Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button text",
          "default": "Book a Consultation"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button URL"
        },
        {
          "type": "select",
          "id": "align",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "spacer",
      "name": "Spacer"
    }
  ],
  "presets": [
    {
      "name": "Consulting",
      "blocks": [
        {
          "type": "large_image",
          "settings": {
            "caption": "Amin Design & Direction — Studio"
          }
        },
        {
          "type": "text_block",
          "settings": {
            "heading": "Manufacturing",
            "body": "<p>End-to-end guidance on taking your design from concept to production. Pattern grading, material sourcing, factory communication, and quality control — built from years of hands-on experience.</p>"
          }
        },
        {
          "type": "image_pair",
          "settings": {
            "offset": true
          }
        },
        {
          "type": "text_block",
          "settings": {
            "heading": "Sampling",
            "body": "<p>Get your first sample right. We cover pattern development, fabric selection, construction techniques, and fit evaluation — so you're not wasting money on rounds of revisions.</p>",
            "align": "right"
          }
        },
        {
          "type": "spacer"
        },
        {
          "type": "large_image",
          "settings": {
            "offset": true,
            "caption": "Production floor detail"
          }
        },
        {
          "type": "text_block",
          "settings": {
            "heading": "Production",
            "body": "<p>Scaling from sample to production run. We consult on production planning, cost optimization, vendor management, and quality assurance to help you ship with confidence.</p>",
            "align": "center"
          }
        },
        {
          "type": "cta",
          "settings": {
            "text": "Book a 15-Min Consultation",
            "align": "center"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
