<style>
  /* Only styles Tailwind can't handle: dynamic grid-column spans + sticky panel blur */
  .product-sticky-panel {
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }
</style>

{% assign current_variant = product.selected_or_first_available_variant %}

<!-- ===== MOBILE LAYOUT ===== -->
<div class="block md:hidden pb-80">
  <!-- 4-col image grid -->
  <div class="grid grid-cols-4 gap-1 p-1">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'product_image' %}
          {% assign col_span = block.settings.mobile_columns | default: 2 %}
          {% assign img_index = block.settings.image_index | default: forloop.index | minus: 1 %}
          {% assign product_image = product.images[img_index] %}
          {% if product_image %}
            <div style="grid-column: span {{ col_span }};" {{ block.shopify_attributes }}>
              {% render 'image', class: 'w-full aspect-square object-cover', image: product_image %}
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    {% else %}
      {% for image in product.images %}
        <div style="grid-column: span 2;">
          {% render 'image', class: 'w-full aspect-square object-cover', image: image %}
        </div>
      {% endfor %}
    {% endif %}
  </div>

  <!-- Sticky bottom panel -->
  <div class="product-sticky-panel fixed bottom-0 left-0 right-0 z-40 bg-white/90 border-t border-black/5 px-6 py-4">
    <div class="flex justify-between items-start mb-3">
      <h1 class="text-base font-bold uppercase tracking-tight m-0">{{ product.title }}</h1>
      <span class="text-sm font-bold">{{ current_variant.price | money }}</span>
    </div>

    {% form 'product', product %}
      <div class="flex flex-col gap-2.5">
        {% if product.variants.size > 1 %}
          <select name="id" class="w-full border border-black text-xs uppercase tracking-wide p-2">
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% if variant == current_variant %}selected{% endif %}>
                {{ variant.title }} - {{ variant.price | money }}
                {% if variant.compare_at_price > variant.price %}
                  {% assign price_difference = variant.compare_at_price | minus: variant.price %}
                  (Save {{ price_difference | money }})
                {% endif %}
              </option>
            {% endfor %}
          </select>
        {% else %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% endif %}

        <input type="hidden" name="quantity" min="1" value="1">
        <input type="submit" value="Add to cart" class="w-full border border-black py-2.5 text-[11px] font-bold uppercase tracking-widest bg-transparent cursor-pointer hover:bg-black hover:text-white transition-colors duration-300">
        <div>{{ form | payment_button }}</div>
      </div>
    {% endform %}

    <details class="mt-3 border-t border-black/10 pt-3">
      <summary class="cursor-pointer text-[11px] font-bold uppercase tracking-widest">Product Details</summary>
      <div class="text-xs text-neutral-500 leading-relaxed mt-2 max-h-36 overflow-y-auto">
        {{ product.description }}
      </div>
    </details>
  </div>
</div>

<!-- ===== DESKTOP LAYOUT ===== -->
<div class="hidden md:grid md:grid-cols-2 md:gap-12 md:px-10 md:py-8">
  <div class="sticky top-20 self-start">
    <h1 class="text-[40px] font-bold uppercase tracking-tighter">{{ product.title }}</h1>

    <div class="mt-6">
      {% form 'product', product %}
        <div class="flex flex-col gap-4">
          {% if product.variants.size > 1 %}
            <select name="id" class="w-full border border-black p-3 text-sm uppercase tracking-wide">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant == current_variant %}selected{% endif %}>
                  {{ variant.title }} - {{ variant.price | money }}
                  {% if variant.compare_at_price > variant.price %}
                    {% assign price_difference = variant.compare_at_price | minus: variant.price %}
                    (Save {{ price_difference | money }})
                  {% endif %}
                </option>
              {% endfor %}
            </select>
          {% else %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {% endif %}

          <input type="hidden" name="quantity" min="1" value="1">
          <input type="submit" value="Add to cart" class="w-full border border-black py-3 text-xs font-bold uppercase tracking-widest bg-transparent cursor-pointer hover:bg-black hover:text-white transition-colors duration-300">
          <div class="mt-2">{{ form | payment_button }}</div>
        </div>
      {% endform %}
    </div>

    <details class="mt-8 border-t border-neutral-200 pt-6">
      <summary class="cursor-pointer text-xs font-bold uppercase tracking-widest">Product Details</summary>
      <div class="mt-4 text-neutral-600 leading-relaxed text-sm">
        {{ product.description }}
      </div>
    </details>
  </div>

  <div class="grid grid-cols-1 gap-4">
    {% for image in product.images %}
      {% render 'image', class: 'w-full', image: image %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "header",
      "content": "Calendly Booking"
    },
    {
      "type": "text",
      "id": "calendly_url_nyc",
      "label": "Calendly URL (nyc tag)",
      "default": "https://calendly.com/aminalisaleh/2x-nyc"
    },
    {
      "type": "text",
      "id": "calendly_url_la",
      "label": "Calendly URL (la tag)",
      "default": "https://calendly.com/aminalisaleh/2x-la"
    },
    {
      "type": "text",
      "id": "calendly_url_virtual",
      "label": "Calendly URL (virtual tag)",
      "default": "https://calendly.com/aminalisaleh/2x-virtual"
    }
  ],
  "blocks": [
    {
      "type": "product_image",
      "name": "Product Image",
      "settings": [
        {
          "type": "range",
          "id": "image_index",
          "label": "Image number (from product)",
          "min": 0,
          "max": 20,
          "step": 1,
          "default": 0
        },
        {
          "type": "range",
          "id": "mobile_columns",
          "label": "Mobile width (of 4 columns)",
          "min": 1,
          "max": 4,
          "step": 1,
          "default": 2
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
