<header class="px-6 md:px-10 py-4 relative">
  <div class="flex items-center justify-between">
    <!-- Hamburger Menu Button -->
    <button id="menu-toggle" class="hamburger z-50 relative">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <!-- Cart Icon -->
    <a href="{{ routes.cart_url }}" class="relative z-50">
      {% if cart.item_count > 0 %}
        <sup class="absolute -top-2 -right-2 bg-black text-white text-xs w-5 h-5 rounded-full flex items-center justify-center">{{ cart.item_count }}</sup>
      {% endif %}
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>

  <!-- Slide-out Menu Panel -->
  <div id="menu-panel" class="menu-panel fixed top-0 left-0 w-full h-full bg-white/60 backdrop-blur-sm transform -translate-x-full transition-transform duration-300 ease-in-out z-40">
    <div class="flex flex-col justify-center items-center h-full">
      {% assign menu_links = linklists[section.settings.menu].links %}
      {% if menu_links.size > 0 %}
        {% for link in menu_links %}
          <a href="{{ link.url }}" class="menu-link text-[40px] md:text-[60px] uppercase tracking-tighter font-bold hover:opacity-60 transition-opacity py-2">
            {{ link.title }}
          </a>
        {% endfor %}
      {% else %}
        <!-- Default menu items -->
        <a href="/collections" class="menu-link text-[40px] md:text-[60px] uppercase tracking-tighter font-bold hover:opacity-60 transition-opacity py-2">Lessons</a>
        <a href="/pages/dnd" class="menu-link text-[40px] md:text-[60px] uppercase tracking-tighter font-bold hover:opacity-60 transition-opacity py-2">D&D</a>
        <a href="{{ routes.cart_url }}" class="menu-link text-[40px] md:text-[60px] uppercase tracking-tighter font-bold hover:opacity-60 transition-opacity py-2">Cart</a>
        <a href="/pages/about" class="menu-link text-[40px] md:text-[60px] uppercase tracking-tighter font-bold hover:opacity-60 transition-opacity py-2">About</a>
        <a href="/pages/contact" class="menu-link text-[40px] md:text-[60px] uppercase tracking-tighter font-bold hover:opacity-60 transition-opacity py-2">Contact</a>
      {% endif %}
    </div>
  </div>
</header>

{% stylesheet %}
  header {
    position: relative;
  }
  header a {
    text-decoration: none;
    color: black;
  }
  header svg {
    width: 1.5rem;
    height: 1.5rem;
  }
  
  /* Hamburger Menu Styles */
  .hamburger {
    width: 24px;
    height: 18px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }
  
  .hamburger-line {
    display: block;
    height: 2px;
    width: 100%;
    background-color: black;
    transition: all 0.3s ease;
  }
  
  .hamburger.menu-open .hamburger-line:first-child {
    transform: rotate(45deg) translate(6px, 6px);
  }
  .hamburger.menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.menu-open .hamburger-line:last-child {
    transform: rotate(-45deg) translate(6px, -6px);
  }
  
  /* Menu Panel */
  .menu-panel.menu-open {
    transform: translateX(0);
  }
  
  .menu-link {
    display: block;
    text-align: center;
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const menuToggle = document.getElementById('menu-toggle');
    const menuPanel = document.getElementById('menu-panel');
    const menuLinks = document.querySelectorAll('.menu-link');
    
    function openMenu() {
      menuToggle.classList.add('menu-open');
      menuPanel.classList.add('menu-open');
      document.body.style.overflow = 'hidden';
    }
    
    function closeMenu() {
      menuToggle.classList.remove('menu-open');
      menuPanel.classList.remove('menu-open');
      document.body.style.overflow = '';
    }
    
    // Toggle menu on hamburger click
    menuToggle.addEventListener('click', function() {
      if (menuPanel.classList.contains('menu-open')) {
        closeMenu();
      } else {
        openMenu();
      }
    });
    
    // Close menu when clicking outside
    menuPanel.addEventListener('click', function(e) {
      if (e.target === menuPanel) {
        closeMenu();
      }
    });
    
    // Close menu on menu link click
    menuLinks.forEach(function(link) {
      link.addEventListener('click', function() {
        closeMenu();
      });
    });
    
    // Close menu on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && menuPanel.classList.contains('menu-open')) {
        closeMenu();
      }
    });
  });
</script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
