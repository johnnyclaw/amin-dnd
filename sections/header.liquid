<style>
  /* Only styles Tailwind can't handle: hamburger animation + slide menu transition */
  .hamburger-line {
    display: block;
    height: 2px;
    width: 100%;
    background-color: black;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .hamburger.is-open .hamburger-line:first-child {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .hamburger-line:last-child {
    transform: rotate(-45deg) translate(6px, -6px);
  }
  .slide-menu {
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    pointer-events: none;
  }
  .slide-menu.is-open {
    transform: translateX(0);
    pointer-events: auto;
  }
</style>

<header class="sticky top-0 z-100 bg-white px-6 md:px-10 py-4">
  <div class="flex items-center justify-between relative">
    <button class="hamburger flex flex-col justify-between w-6 h-[18px] bg-transparent border-none p-0 cursor-pointer relative z-[1]" id="hamburger-btn" aria-label="Menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    {% if section.settings.logo %}
      <a href="{{ routes.root_url }}" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <img src="{{ 'logo.png' | asset_url: "24x24" }}" height="24px" width="auto" alt="Description of image" />
      </a>
    {% else %}
      <a href="{{ routes.root_url }}" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <img src="https://cdn.shopify.com/s/files/1/0813/2401/5851/files/logo.png?v=1772656190" height="24px" width="auto" alt="Description of image" />
      </a>
    {% endif %}

    <a href="{{ routes.cart_url }}" class="relative no-underline text-black">
      {% if cart.item_count > 0 %}
        <sup class="absolute -top-2 -right-2 bg-black text-white text-[10px] w-[18px] h-[18px] rounded-full flex items-center justify-center">{{ cart.item_count }}</sup>
      {% endif %}
      <span class="w-6 h-6 block">{{ 'icon-cart.svg' | inline_asset_content }}</span>
    </a>
  </div>
</header>

<div class="slide-menu fixed top-0 left-0 w-full h-full bg-white/60 backdrop-blur-md z-99 overflow-y-auto" id="slide-menu">
  <div class="flex flex-col items-center justify-center min-h-full pt-24 px-8 pb-8 md:flex-row md:pt-8">
    <div class="flex flex-col items-center md:flex-1 md:items-start md:pl-12">
      {% assign menu_links = linklists[section.settings.menu].links %}
      {% if menu_links.size > 0 %}
        {% for link in menu_links %}
          <a href="{{ link.url }}" class="block text-center text-[36px] md:text-[60px] md:text-left font-bold uppercase tracking-tighter leading-tight py-1 text-black no-underline hover:opacity-50 transition-opacity">
            {{ link.title }}
          </a>
        {% endfor %}
      {% else %}
        <a href="/collections" class="block text-center text-[36px] md:text-[60px] md:text-left font-bold uppercase tracking-tighter leading-tight py-1 text-black no-underline hover:opacity-50 transition-opacity">Lessons</a>
        <a href="/pages/dnd" class="block text-center text-[36px] md:text-[60px] md:text-left font-bold uppercase tracking-tighter leading-tight py-1 text-black no-underline hover:opacity-50 transition-opacity">D&D</a>
        <a href="{{ routes.cart_url }}" class="block text-center text-[36px] md:text-[60px] md:text-left font-bold uppercase tracking-tighter leading-tight py-1 text-black no-underline hover:opacity-50 transition-opacity">Cart</a>
        <a href="/pages/about" class="block text-center text-[36px] md:text-[60px] md:text-left font-bold uppercase tracking-tighter leading-tight py-1 text-black no-underline hover:opacity-50 transition-opacity">About</a>
        <a href="/pages/contact" class="block text-center text-[36px] md:text-[60px] md:text-left font-bold uppercase tracking-tighter leading-tight py-1 text-black no-underline hover:opacity-50 transition-opacity">Contact</a>
      {% endif %}
    </div>

    {% if section.settings.menu_image %}
      <div class="mt-8 w-4/5 max-w-[300px] md:flex-1 md:mt-0 md:max-w-none md:w-auto md:flex md:items-center md:justify-center md:p-8">
        {{ section.settings.menu_image | image_url: width: 800 | image_tag:
          class: 'w-full h-auto object-cover md:max-h-[70vh] md:w-auto md:max-w-full',
          loading: 'lazy'
        }}
      </div>
    {% endif %}
  </div>
</div>

<script>
  (function() {
    var btn = document.getElementById('hamburger-btn');
    var menu = document.getElementById('slide-menu');
    if (!btn || !menu) return;

    var scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;

    function openMenu() {
      menu.classList.add('is-open');
      btn.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      document.body.style.paddingRight = scrollbarWidth + 'px';
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      btn.classList.remove('is-open');
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
    }

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      if (menu.classList.contains('is-open')) { closeMenu(); } else { openMenu(); }
    });

    menu.addEventListener('click', function(e) {
      if (e.target === menu || e.target.closest('.slide-menu > div') === e.target) { closeMenu(); }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) { closeMenu(); }
    });
  })();
</script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "image_picker",
      "id": "menu_image",
      "label": "Menu image (shown beside links)"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
