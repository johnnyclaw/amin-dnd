<style>
  header.site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: white;
  }
  header.site-header a {
    text-decoration: none;
    color: black;
  }
  header.site-header svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .hamburger {
    width: 24px;
    height: 18px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    position: relative;
    z-index: 70;
  }
  .hamburger-line {
    display: block;
    height: 2px;
    width: 100%;
    background-color: black;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .hamburger.is-open .hamburger-line:first-child {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .hamburger-line:last-child {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  .header-logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 70;
  }
  .header-logo img {
    height: 2rem;
    width: auto;
  }

  .slide-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 65;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    pointer-events: none;
    overflow-y: auto;
  }
  .slide-menu.is-open {
    transform: translateX(0);
    pointer-events: auto;
  }

  /* Desktop: split layout — menu left, image right */
  .slide-menu-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100%;
    padding: 6rem 2rem 2rem;
  }
  @media (min-width: 768px) {
    .slide-menu-inner {
      flex-direction: row;
      padding: 2rem;
    }
  }

  .slide-menu-links {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  @media (min-width: 768px) {
    .slide-menu-links {
      flex: 1;
      align-items: flex-start;
      padding-left: 3rem;
    }
  }

  .slide-menu-links a {
    display: block;
    text-align: center;
    font-size: 36px;
    line-height: 1.1;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    padding: 0.25rem 0;
    transition: opacity 0.2s ease;
    color: black;
    text-decoration: none;
  }
  .slide-menu-links a:hover {
    opacity: 0.5;
  }
  @media (min-width: 768px) {
    .slide-menu-links a {
      font-size: 60px;
      text-align: left;
    }
  }

  .slide-menu-image {
    margin-top: 2rem;
    width: 80%;
    max-width: 300px;
  }
  @media (min-width: 768px) {
    .slide-menu-image {
      flex: 1;
      margin-top: 0;
      max-width: none;
      width: auto;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
  }
  .slide-menu-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  @media (min-width: 768px) {
    .slide-menu-image img {
      max-height: 70vh;
      width: auto;
      max-width: 100%;
    }
  }
</style>

<header class="site-header px-6 md:px-10 py-4">
  <div class="flex items-center justify-between" style="position: relative;">
    <button class="hamburger" id="hamburger-btn" aria-label="Menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    {% if section.settings.logo %}
      <a href="{{ routes.root_url }}" class="header-logo">
        {{ section.settings.logo | image_url: height: 64 | image_tag }}
      </a>
    {% else %}
      <a href="{{ routes.root_url }}" class="header-logo" style="font-weight: 700; font-size: 1rem; text-transform: uppercase; letter-spacing: -0.03em;">
        {{ shop.name }}
      </a>
    {% endif %}

    <a href="{{ routes.cart_url }}" style="position: relative; z-index: 70;">
      {% if cart.item_count > 0 %}
        <sup style="position: absolute; top: -8px; right: -8px; background: black; color: white; font-size: 10px; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">{{ cart.item_count }}</sup>
      {% endif %}
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

<div class="slide-menu" id="slide-menu">
  <div class="slide-menu-inner">
    <div class="slide-menu-links">
      {% assign menu_links = linklists[section.settings.menu].links %}
      {% if menu_links.size > 0 %}
        {% for link in menu_links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/collections">Lessons</a>
        <a href="/pages/dnd">D&D</a>
        <a href="{{ routes.cart_url }}">Cart</a>
        <a href="/pages/about">About</a>
        <a href="/pages/contact">Contact</a>
      {% endif %}
    </div>

    {% if section.settings.menu_image %}
      <div class="slide-menu-image">
        {{ section.settings.menu_image | image_url: width: 800 | image_tag:
          loading: 'lazy'
        }}
      </div>
    {% endif %}
  </div>
</div>

<script>
  (function() {
    var btn = document.getElementById('hamburger-btn');
    var menu = document.getElementById('slide-menu');
    if (!btn || !menu) return;

    // Calculate scrollbar width to prevent content shift
    var scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;

    function openMenu() {
      menu.classList.add('is-open');
      btn.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      document.body.style.paddingRight = scrollbarWidth + 'px';
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      btn.classList.remove('is-open');
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
    }

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      if (menu.classList.contains('is-open')) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    menu.addEventListener('click', function(e) {
      if (e.target === menu || e.target.classList.contains('slide-menu-inner')) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) {
        closeMenu();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "image_picker",
      "id": "menu_image",
      "label": "Menu image (shown beside links)"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
