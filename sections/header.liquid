<style>
  header.site-header {
    position: relative;
  }
  header.site-header a {
    text-decoration: none;
    color: black;
  }
  header.site-header svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .hamburger {
    width: 24px;
    height: 18px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    position: relative;
    z-index: 60;
  }
  .hamburger-line {
    display: block;
    height: 2px;
    width: 100%;
    background-color: black;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .hamburger.is-open .hamburger-line:first-child {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .hamburger-line:last-child {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  .slide-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 50;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    pointer-events: none;
  }
  .slide-menu.is-open {
    transform: translateX(0);
    pointer-events: auto;
  }
  .slide-menu a {
    display: block;
    text-align: center;
    font-size: 40px;
    line-height: 1.1;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    padding: 0.25rem 0;
    transition: opacity 0.2s ease;
  }
  .slide-menu a:hover {
    opacity: 0.5;
  }
  @media (min-width: 768px) {
    .slide-menu a {
      font-size: 60px;
    }
  }
</style>

<header class="site-header px-6 md:px-10 py-4">
  <div class="flex items-center justify-between">
    <button class="hamburger" id="hamburger-btn" aria-label="Menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <a href="{{ routes.cart_url }}" style="position: relative; z-index: 60;">
      {% if cart.item_count > 0 %}
        <sup style="position: absolute; top: -8px; right: -8px; background: black; color: white; font-size: 10px; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">{{ cart.item_count }}</sup>
      {% endif %}
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

<div class="slide-menu" id="slide-menu">
  {% assign menu_links = linklists[section.settings.menu].links %}
  {% if menu_links.size > 0 %}
    {% for link in menu_links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
  {% else %}
    <a href="/collections">Lessons</a>
    <a href="/pages/dnd">D&D</a>
    <a href="{{ routes.cart_url }}">Cart</a>
    <a href="/pages/about">About</a>
    <a href="/pages/contact">Contact</a>
  {% endif %}
</div>

<script>
  (function() {
    var btn = document.getElementById('hamburger-btn');
    var menu = document.getElementById('slide-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var open = menu.classList.contains('is-open');
      if (open) {
        menu.classList.remove('is-open');
        btn.classList.remove('is-open');
        document.body.style.overflow = '';
      } else {
        menu.classList.add('is-open');
        btn.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
    });

    menu.addEventListener('click', function(e) {
      if (e.target === menu) {
        menu.classList.remove('is-open');
        btn.classList.remove('is-open');
        document.body.style.overflow = '';
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) {
        menu.classList.remove('is-open');
        btn.classList.remove('is-open');
        document.body.style.overflow = '';
      }
    });
  })();
</script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
