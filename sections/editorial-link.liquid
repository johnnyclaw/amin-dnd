{% comment %}
  Reusable editorial link section.
  Sticky heading on the left, stacked images on the right.
  Links to a collection or page — configurable via schema.
{% endcomment %}

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 pt-12">
  <div class="relative">
    <a href="{{ section.settings.url }}" class="sticky top-12 block">
      <h2 class="tracking-tighter font-bold text-[32px] md:text-[40px] uppercase">{{ section.settings.heading }}</h2>
      <h3 class="tracking-tighter pl-7 text-[32px] md:text-[40px] leading-none">{{ section.settings.subheading }}</h3>
    </a>
  </div>
  <div>
    <a href="{{ section.settings.url }}" class="flex flex-col gap-4">
      {% for block in section.blocks %}
        {% if block.type == 'image' and block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 1200 | image_tag:
            class: 'w-full h-auto',
            loading: 'lazy'
          }}
        {% endif %}
      {% endfor %}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Editorial Link",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Design"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lessons"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Link URL"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Link",
      "blocks": [
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
