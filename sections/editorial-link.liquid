{% comment %}
  Reusable editorial link section.
  Sticky heading on the left, images on the right.
  Links to a collection, page, or product — configurable via schema.

  Layout modes:
  - "stacked" (default): images stack vertically (homepage style)
  - "grid": images in a 2-col grid with optional full-width per image (collection style)
{% endcomment %}

{% assign layout = section.settings.layout | default: 'stacked' %}

<div class="grid grid-cols-1 {% if layout == 'grid' %}md:grid-cols-3{% else %}md:grid-cols-2{% endif %} gap-6 md:gap-12 pt-12">
  <div class="relative">
    <a href="{{ section.settings.url }}" class="sticky top-12 block">
      <h2 class="tracking-tighter font-bold text-[32px] md:text-[40px] uppercase">{{ section.settings.heading }}</h2>
      <h3 class="tracking-tighter pl-7 text-[32px] md:text-[40px] leading-none">{{ section.settings.subheading }}</h3>
    </a>
  </div>

  {% if layout == 'grid' %}
    <div class="col-span-1 md:col-span-2 grid gap-6 md:gap-12 grid-cols-1 sm:grid-cols-2">
      {% for block in section.blocks %}
        {% if block.type == 'image' %}
          {% assign width_class = '' %}
          {% if block.settings.full_width %}
            {% assign width_class = 'sm:col-span-2' %}
          {% endif %}
          <a href="{{ section.settings.url }}" class="flex flex-col gap-4 {{ width_class }}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1200 | image_tag:
                class: 'w-full h-auto',
                loading: 'lazy'
              }}
            {% else %}
              <div class="w-full aspect-[4/5] bg-neutral-100 flex items-center justify-center text-neutral-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div>
      <a href="{{ section.settings.url }}" class="flex flex-col gap-4">
        {% for block in section.blocks %}
          {% if block.type == 'image' %}
            <div {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1200 | image_tag:
                  class: 'w-full h-auto',
                  loading: 'lazy'
                }}
              {% else %}
                <div class="w-full aspect-[4/5] bg-neutral-100 flex items-center justify-center text-neutral-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </a>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Editorial Link",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Design"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lessons"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Link URL"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image layout",
      "options": [
        { "value": "stacked", "label": "Stacked (homepage)" },
        { "value": "grid", "label": "Grid (collection)" }
      ],
      "default": "stacked"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "full_width",
          "label": "Full width (grid layout only)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Link",
      "blocks": [
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
