{% comment %}
  Projects Index - displays all projects (blog articles) in a grid layout.
  Uses the editorial-link pattern with sticky heading on left, grid on right.
{% endcomment %}

<div class="px-6 md:px-10 pt-12">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-12">
    <!-- Sticky Projects Heading -->
    <div class="relative">
      <div class="sticky top-12">
        <h1 class="tracking-tighter font-bold text-[40px] md:text-[60px] uppercase">Projects</h1>
      </div>
    </div>

    <!-- Projects Grid -->
    <div class="col-span-1 md:col-span-2">
      {% paginate blog.articles by 8 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
          {% for article in blog.articles %}
            <a href="{{ article.url }}" class="project-card group">
              <div class="project-image mb-4 overflow-hidden">
                {% if article.image %}
                  {{ article.image | image_url: width: 600 | image_tag:
                    class: 'w-full h-auto transition-transform duration-300 group-hover:scale-105',
                    loading: 'lazy'
                  }}
                {% else %}
                  <div class="w-full aspect-[4/5] bg-neutral-100 flex items-center justify-center text-neutral-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                {% endif %}
              </div>
              <h2 class="project-title text-sm uppercase tracking-widest font-bold mt-2 group-hover:opacity-60 transition-opacity">
                {{ article.title }}
              </h2>
            </a>
          {% endfor %}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="mt-12">
            {{- paginate | default_pagination -}}
          </div>
        {%- endif -%}
      {% endpaginate %}
    </div>
  </div>
</div>

{% stylesheet %}
  .project-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  
  .project-image {
    position: relative;
  }
  
  .project-title {
    color: black;
  }
  
  .project-card:hover .project-title {
    opacity: 0.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.blog",
  "settings": []
}
{% endschema %}
