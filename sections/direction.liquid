{% comment %}
  Direction page — Our Legacy /projects style
  2-column editorial grid showcasing courses/lessons
{% endcomment %}

<section class="py-16 md:py-24">
  <!-- Page Title -->
  <div class="mb-16 md:mb-24 px-6 md:px-10">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold uppercase tracking-tighter leading-none">
      {{ page.title | default: 'Direction' }}
    </h1>
    {% if section.settings.subtitle != blank %}
      <p class="mt-4 text-sm md:text-base text-neutral-500 max-w-lg">
        {{ section.settings.subtitle }}
      </p>
    {% endif %}
  </div>

  <!-- 2-Column Project Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 md:gap-x-6 gap-y-12 md:gap-y-20 px-6 md:px-10">
    {% for block in section.blocks %}
      {% if block.type == 'project_card' %}
        <a
          href="{{ block.settings.link | default: '#' }}"
          {% assign mod_check = forloop.index0 | modulo: 2 %}
          class="group block {% if mod_check == 1 %}md:mt-16{% endif %}"
          {{ block.shopify_attributes }}
        >
          <!-- Image -->
          <div class="aspect-[4/5] bg-neutral-100 overflow-hidden mb-4">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                class: 'w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-80',
                loading: 'lazy'
              }}
            {% else %}
              <div class="w-full h-full flex items-center justify-center text-neutral-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            {% endif %}
          </div>

          <!-- Label + Title -->
          <div class="space-y-1">
            {% if block.settings.category != blank %}
              <p class="text-xs uppercase tracking-widest text-neutral-500 font-bold">
                {{ block.settings.category }}
              </p>
            {% endif %}
            <p class="text-sm">
              {{ block.settings.title }}
            </p>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Direction",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "In-person and virtual design education. Pattern making, garment construction, and the foundations rarely taught in school."
    }
  ],
  "blocks": [
    {
      "type": "project_card",
      "name": "Course Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category label",
          "default": "MASTERCLASS"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Course Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Direction",
      "blocks": [
        {
          "type": "project_card",
          "settings": {
            "category": "MASTERCLASS",
            "title": "Carpenter Jean Masterclass"
          }
        },
        {
          "type": "project_card",
          "settings": {
            "category": "MASTERCLASS",
            "title": "Denim Jacket Masterclass"
          }
        },
        {
          "type": "project_card",
          "settings": {
            "category": "1:1 LESSON",
            "title": "2x Design Lessons — LA"
          }
        },
        {
          "type": "project_card",
          "settings": {
            "category": "VIRTUAL",
            "title": "2x Virtual Design Lessons"
          }
        },
        {
          "type": "project_card",
          "settings": {
            "category": "1:1 LESSON",
            "title": "14x Design Lessons — LA"
          }
        },
        {
          "type": "project_card",
          "settings": {
            "category": "YOUTH",
            "title": "2x Youth Design Lessons — LA"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
