<style>
  /* Only styles Tailwind can't handle: scale transition + icon swap */
  .contact-form-panel {
    transform: scale(0);
    transform-origin: bottom right;
    transition: transform 0.3s ease;
    pointer-events: none;
  }
  .contact-widget.is-open .contact-form-panel {
    transform: scale(1);
    pointer-events: auto;
  }
  .contact-btn .icon-close { opacity: 0; }
  .contact-widget.is-open .contact-btn .icon-mail { opacity: 0; }
  .contact-widget.is-open .contact-btn .icon-close { opacity: 1; }
</style>

<div class="contact-widget fixed bottom-6 right-6 z-50" id="contact-widget">
  <!-- Trigger Button -->
  <button class="contact-btn w-14 h-14 bg-black hover:bg-neutral-800 text-white rounded-full shadow-lg flex items-center justify-center transition-all duration-300 relative border-none cursor-pointer" id="contact-btn" aria-label="Contact">
    <svg class="icon-mail w-6 h-6 absolute transition-opacity duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
    </svg>
    <svg class="icon-close w-6 h-6 absolute transition-opacity duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>

  <!-- Contact Form Panel -->
  <div class="contact-form-panel absolute bottom-16 right-0 w-80 max-sm:w-[calc(100vw-3rem)] bg-white rounded-lg shadow-xl border border-neutral-200 p-6" id="contact-panel">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-xs uppercase tracking-widest font-bold">Contact Us</h3>
      <button id="panel-close-btn" class="text-neutral-400 hover:text-neutral-600 transition-colors bg-transparent border-none cursor-pointer text-xl leading-none">×</button>
    </div>

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded text-green-800 text-sm">
          Thank you! We'll get back to you soon.
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded text-red-800 text-sm">
          {% for field in form.errors %}
            <p>{{ field | capitalize }} {{ form.errors.messages[field] }}</p>
          {% endfor %}
        </div>
      {% endif %}

      <div class="flex flex-col gap-3">
        <div>
          <label for="cw-name" class="block text-xs font-medium text-neutral-700 mb-1">Name</label>
          <input type="text" name="contact[name]" id="cw-name" value="{{ form.name }}" required class="border border-neutral-300 p-3 w-full text-sm rounded focus:outline-none focus:border-neutral-500">
        </div>
        <div>
          <label for="cw-email" class="block text-xs font-medium text-neutral-700 mb-1">Email</label>
          <input type="email" name="contact[email]" id="cw-email" value="{{ form.email }}" required class="border border-neutral-300 p-3 w-full text-sm rounded focus:outline-none focus:border-neutral-500">
        </div>
        <div>
          <label for="cw-message" class="block text-xs font-medium text-neutral-700 mb-1">Message</label>
          <textarea name="contact[body]" id="cw-message" rows="4" required class="border border-neutral-300 p-3 w-full text-sm rounded focus:outline-none focus:border-neutral-500 resize-none">{{ form.body }}</textarea>
        </div>
        <button type="submit" class="w-full bg-black text-white py-3 text-xs uppercase tracking-widest font-bold hover:bg-neutral-800 transition-colors rounded border-none cursor-pointer">
          Send Message
        </button>
      </div>
    {% endform %}
  </div>
</div>

<script>
  (function() {
    var widget = document.getElementById('contact-widget');
    var btn = document.getElementById('contact-btn');
    var closeBtn = document.getElementById('panel-close-btn');
    if (!widget || !btn) return;

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      widget.classList.toggle('is-open');
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        widget.classList.remove('is-open');
      });
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') widget.classList.remove('is-open');
    });

    document.addEventListener('click', function(e) {
      if (!widget.contains(e.target)) widget.classList.remove('is-open');
    });
  })();
</script>

{% schema %}
{
  "name": "Contact Widget",
  "settings": [],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
